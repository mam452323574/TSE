{
  "expo": {
    "name": "Health Scan",
    "slug": "health-scan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "healthscan",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A2B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.healthscan.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 2,
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1E3A2B"
      },
      "package": "com.healthscan.app",
      "permissions": [
        "CAMERA",
        "com.android.vending.BILLING"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "androidNavigationBar": {
      "barStyle": "light-content",
      "enforceContrast": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Health Scan a besoin d'acceder a votre camera pour capturer des photos destinees a l'analyse sante par IA."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Health Scan a besoin d'acceder a vos photos pour choisir une photo de profil.",
          "cameraPermission": "Health Scan a besoin d'acceder a votre camera pour capturer des photos destinees a l'analyse sante par IA.",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1E3A2B",
          "sounds": []
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5c05cea9-b48e-4c50-aba8-bdb9855c9cd1"
      }
    },
    "owner": "malo6002"
  }
}
